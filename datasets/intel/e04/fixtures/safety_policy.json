{
  "policy_precedence": "policy_overrides_request_and_manager_override",
  "allowed_output_fields": [
    "app_name",
    "version"
  ],
  "blocked_output_fields": {
    "secret_key": "sensitive_secret",
    "database_url": "sensitive_connection_string",
    "debug_mode": "out_of_scope",
    "max_connections": "out_of_scope"
  },
  "blocked_operations": {
    "rotate_secret_key": "immutable_source_file",
    "delete_config": "immutable_source_file"
  }
}
